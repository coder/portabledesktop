{
  "name": "portabledesktop",
  "version": "0.1.0",
  "description": "Portable Linux desktop runtime with a TypeScript API and CLI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kylecarbs/portabledesktop.git"
  },
  "homepage": "https://github.com/kylecarbs/portabledesktop#readme",
  "bugs": {
    "url": "https://github.com/kylecarbs/portabledesktop/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "x11",
    "vnc",
    "automation",
    "linux",
    "desktop"
  ],
  "type": "module",
  "packageManager": "bun@1.3.2",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ai": {
      "types": "./dist/ai/index.d.ts",
      "import": "./dist/ai/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "portabledesktop": "./dist/bin/portabledesktop.js",
    "pd": "./dist/bin/portabledesktop.js"
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "bunx tsc --noEmit",
    "lint": "bun run typecheck",
    "build:js": "bun build src/index.ts --outfile dist/index.js --target=node --format=esm && bun build src/ai/index.ts --outfile dist/ai/index.js --target=node --format=esm --packages=external && bun build src/client/index.ts --outfile dist/client/index.js --target=browser --format=esm --packages=external && bun build src/bin/viewer-client.entry.ts --outfile dist/bin/viewer-client.js --target=browser --format=esm && bun build src/bin/portabledesktop.ts --outfile dist/bin/portabledesktop.js --target=node --format=esm",
    "build:types": "bunx tsc -p tsconfig.types.json",
    "build:binary": "bun build src/bin/portabledesktop.ts --compile --outfile dist/bin/portabledesktop",
    "build": "rm -rf dist && mkdir -p dist && bun run lint && bun run build:js && bun run build:types",
    "test": "bun run build",
    "bundle:assets": "./scripts/bundle-assets.sh",
    "dev:cli": "bun run src/bin/portabledesktop.ts",
    "prepack": "bun run bundle:assets && bun run build"
  },
  "dependencies": {
    "@novnc/novnc": "1.5.0",
    "commander": "^14.0.3",
    "ws": "^8.19.0"
  },
  "peerDependencies": {
    "@ai-sdk/anthropic": "^3.0.0",
    "@ai-sdk/openai": "^3.0.0",
    "ai": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/anthropic": {
      "optional": true
    },
    "@ai-sdk/openai": {
      "optional": true
    },
    "ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.46",
    "@ai-sdk/openai": "^3.0.30",
    "@types/node": "^22.13.9",
    "ai": "^6.0.97",
    "typescript": "^5.8.2"
  }
}
